@page "/board/{BoardId}"
@using KanbanBoard.Application.DTOs.Board
@using KanbanBoard.Presentation.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject BoardApiService BoardApiService
@inject ColumnApiService ColumnApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" Class="mb-2">@_board?.Title</MudText>
<MudText Typo="Typo.body1" Color="Color.Tertiary" Class="mb-4">@_board?.Description</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="@OpenCreateColumnDialog" Class="mb-4">
    Add Column
</MudButton>

<MudButton Variant="Variant.Text" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack"
           OnClick="@(() => Navigation.NavigateTo($"/workspace/{_board?.WorkspaceId}"))" Class="mb-4 ml-2">
    Back to Workspace
</MudButton>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_board?.Columns != null && _board.Columns.Any())
{
    <MudGrid>
        @foreach (var column in _board.Columns.OrderBy(c => c.Order))
        {
            <MudItem xs="12" sm="6" md="4">
                <ColumnCard Column="@column" OnTaskMoved="@LoadBoard" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudText Typo="Typo.body1" Color="Color.Tertiary">No columns found. Add your first column!</MudText>
}